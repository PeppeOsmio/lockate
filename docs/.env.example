# PostgreSQL credentials - used by postgres container and passed to the app
POSTGRES_USER=admin
POSTGRES_PASSWORD=1234

# Redis/Valkey password
REDIS_PASSWORD=1234

# Whether the API requires an API key for all requests
REQUIRE_API_KEY=false

# --- Optional: override app defaults (not required for docker-compose deploys) ---

# App port (default: 3118)
# SERVER_PORT=3118

# Request logging level (default: DEBUG)
# REQUEST_LOGGING_LEVEL=DEBUG

# Location retention cron expression (default: midnight daily)
# RETENTION_ANONYMOUS_GROUP_LOCATION_CRON=0 0 0 * * *

# How long to keep location records (ISO-8601 duration, default: 7 days)
# RETENTION_ANONYMOUS_GROUP_LOCATION_DURATION=P7D

# Minimum interval between location saves per member (ISO-8601 duration, default: 2 min)
# RETENTION_ANONYMOUS_GROUP_LOCATION_SAVE_INTERVAL=PT2M
